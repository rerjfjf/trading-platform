# Скопируйте в .env в корне (для Python API) и при необходимости в auth-service/.env, frontend/.env.local

# --- Docker Compose (опционально, переопределение дефолтов) ---
# POSTGRES_USER=trading
# POSTGRES_PASSWORD=trading_dev_change_me
# POSTGRES_DB=trading_platform
# POSTGRES_PORT=5432

# --- Python API (uvicorn из корня проекта) ---
# После `docker compose up` используйте те же user/password/db что в compose:
DATABASE_URL=postgresql://trading:trading_dev_change_me@localhost:5432/trading_platform

AUTH_SERVICE_URL=http://localhost:3001/auth
ALLOWED_ORIGINS=http://localhost:3000

GROQ_KEY=

# Лимит запросов к Groq на пользователя (токен) для POST /ai/chat (slowapi)
# Формат: "число/period", period: second|minute|hour|day
AI_CHAT_RATE_LIMIT=30/minute

# --- React (frontend/.env.local) ---
# REACT_APP_API_URL=http://localhost:8000
# REACT_APP_AUTH_URL=http://localhost:3001

# --- auth-service (auth-service/.env) — см. также auth-service/.env.example ---
# DB_URL=postgresql://trading:trading_dev_change_me@localhost:5432/trading_auth
# JWT_SECRET=сгенерируйте_длинную_случайную_строку
# JWT_EXPIRES_IN=7d
# NODE_ENV=development
# ALLOWED_ORIGINS=http://localhost:3000
# Первый админ только явно (пароль ≥ 12 символов):
# CREATE_DEFAULT_ADMIN=true
# DEFAULT_ADMIN_PASSWORD=
