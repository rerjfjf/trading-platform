# Скопируйте в .env и подставьте значения.
# При Docker Postgres из корня репозитория см. docker-compose.yml и корневой .env.example

PORT=3001
NODE_ENV=development

# Одна строка подключения к БД пользователей (отдельная БД trading_auth)
DB_URL=postgresql://trading:trading_dev_change_me@localhost:5432/trading_auth

# Сгенерируйте: openssl rand -base64 48
# В production длина не менее 32 символов (сервис проверит при старте)
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# CORS: домены фронта через запятую
ALLOWED_ORIGINS=http://localhost:3000

# Только для первого запуска / dev: создать admin (пароль ≥ 12 символов)
# После входа смените пароль и отключите CREATE_DEFAULT_ADMIN
# CREATE_DEFAULT_ADMIN=true
# DEFAULT_ADMIN_PASSWORD=
